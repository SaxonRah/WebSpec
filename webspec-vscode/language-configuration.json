{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["(", ")"],
        ["'", "'"],
        ["${", "}"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" },
        { "open": "${", "close": "}" }
    ],
    "surroundingPairs": [
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" },
        { "open": "(", "close": ")" }
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(if|repeat|for|try|define|using)\\b",
            "end": "^\\s*end\\b"
        }
    },
    "wordPattern": "\\$\\{?[a-zA-Z_][a-zA-Z0-9_]*\\}?|[a-zA-Z_][a-zA-Z0-9_]*",
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(if|repeat|for|try|define|using|else|on error)\\b.*$",
        "decreaseIndentPattern": "^\\s*(end|else|on error)\\b"
    }
}